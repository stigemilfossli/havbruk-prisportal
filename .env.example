# === Havbruk Prisportal – Production Environment ===
# Copy this to .env and fill in real values before running deploy.sh

# The public URL of the site (your subdomain, e.g. https://demo.dindomene.no)
BASE_URL=https://demo.dindomene.no

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://demo.dindomene.no

# JWT secret – generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key

# SendGrid (optional – needed for email quotes)
SENDGRID_API_KEY=
FROM_EMAIL=demo@dindomene.no
FROM_NAME=Havbruk Prisportal

# Stripe (optional – needed for payment integration)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
